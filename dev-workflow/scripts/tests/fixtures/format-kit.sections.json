  "default": {
    "class": "A",
    "required_sections": [],
    "allowed_sections": [
      "## For human",
      "## Summary",
      "## Status",
      "## State",
      "## Context",
      "## Tasks",
      "## Decisions",
      "## Risks",
      "## Notes",
      "## References",
      "## Procedures",
      "## Revision history",
      "## Automated checks",
      "## Verdict",
      "## Issues",
      "## Scorecard"
    ],
    "notes": "fallback for artifacts not matching any named type; broad allowed_sections to avoid spurious V-02 failures on ad-hoc files"
  }
